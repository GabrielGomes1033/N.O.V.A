# Copie este arquivo para .env.nova e preencha as chaves.
# Exemplo:
#   cp .env.nova.example .env.nova

# Opcional: Brave Search API (preferencial)
NOVA_BRAVE_API_KEY=

# Opcional: SerpAPI (fallback premium)
NOVA_SERPAPI_KEY=

# Opcional: criação de projetos no Notion
# Token da integração interna do Notion
NOVA_NOTION_TOKEN=
# Destino preferencial: use o data source ID do banco de projetos
NOVA_NOTION_PROJECTS_DATA_SOURCE_ID=
# Alternativa legada: use o database ID para a NOVA resolver o primeiro data source
NOVA_NOTION_PROJECTS_DATABASE_ID=
# Alternativa: use um page ID para criar subpáginas em vez de itens de banco
NOVA_NOTION_PROJECTS_PAGE_ID=
# Opcional: se sua base usa um nome diferente para a coluna de título
NOVA_NOTION_PROJECTS_TITLE_PROPERTY=
# Opcional: nomes explícitos das outras colunas
NOVA_NOTION_PROJECTS_DESCRIPTION_PROPERTY=
NOVA_NOTION_PROJECTS_AREA_PROPERTY=
NOVA_NOTION_PROJECTS_PRIORITY_PROPERTY=
NOVA_NOTION_PROJECTS_RESPONSIBLE_PROPERTY=
NOVA_NOTION_PROJECTS_LINK_PROPERTY=
# Opcional: se quiser preencher o status inicial ao criar o projeto
NOVA_NOTION_PROJECTS_STATUS_PROPERTY=
NOVA_NOTION_PROJECTS_STATUS_VALUE=
# Opcional: provider padrão para /projeto e frases naturais (notion ou drive)
NOVA_PROJECT_PROVIDER=notion

# Opcional: host/porta padrão para o script start_api.sh
NOVA_API_HOST=0.0.0.0
NOVA_API_PORT=8000

# Opcional: caminho do Python para subir a API (ex.: venv com edge-tts)
# NOVA_PYTHON_BIN=./venv311/bin/python
